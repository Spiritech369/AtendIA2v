      "aliases": ["document"]
    }
  ],
  "pipeline": {
    "stages": ["new", "selection", "quoted", "requirements"]
  },
  "workflow_events": [
    "lead_started",
    "selection_identified",
    "offer_quoted",
    "requirements_requested"
  ],
  "guards": [
    "mandatory_tool_guard",
    "final_copy_guard",
    "tenant_isolation_guard"
  ],
  "frontend": {
    "field_groups": ["selection", "quote", "requirements"]
  },
  "trace": {},
  "safety": {}
