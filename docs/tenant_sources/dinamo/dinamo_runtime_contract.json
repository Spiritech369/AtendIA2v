      "write_policy": "auto_apply_when_explicit",
      "allowed_sources": ["user_message"],
      "evidence_required": true,
      "validation": {"minimum_months": 6}
    },
    {
      "key": "cumple_antiguedad",
      "label": "Cumple antiguedad",
      "type": "boolean",
      "domain_role": "employment_seniority_eligibility",
