      "domain_role": "selection_metadata",
      "aliases": ["modelo_moto_id", "catalog_id", "product_id"],
      "write_policy": "tool_only",
      "allowed_sources": ["catalog.search"],
      "evidence_required": true
    },
    {
      "key": "employment_seniority",
      "label": "Antiguedad laboral",
