  "tools": [
    {"tool_id": "catalog.search", "topic": "catalog_or_listing", "aliases": ["catalog", "modelos", "inventario"]},
    {"tool_id": "credit_plan.resolve", "topic": "plan_or_financing", "aliases": ["plan", "credit_plan", "enganche"]},
    {"tool_id": "quote.resolve", "topic": "offer_or_quote", "aliases": ["quote", "cotizacion", "precio"]},
    {"tool_id": "requirements.lookup", "topic": "requirements", "aliases": ["requirements", "requisitos", "papeleria"]},
    {"tool_id": "faq.lookup", "topic": "policy_or_faq", "aliases": ["faq", "buro", "politicas"]},
    {"tool_id": "document.check", "topic": "document_status", "aliases": ["document", "documentos"]},
    {"tool_id": "expediente.evaluate", "topic": "document_completeness", "aliases": ["expediente", "documentos_completos"]}
  ],
  "flow_policy": {
    "single_question_per_turn": true,
    "do_not_repeat_saved_data": true,
    "do_not_request_documents_before_quote": true,
    "do_not_promise_approval": true,
    "document_received_is_not_document_approved": true,
    "ask_only_missing_documents": true,
    "seniority_before_income": true,
    "seniority_slot": "employment_seniority",
    "income_slot": "income_type",
    "seniority_minimum_months": 6,
    "business_activity_ambiguous_slot": "business_tax_status",
    "business_activity_clarification": "Va, si tienes negocio. Para darte el plan correcto dime si estas dado de alta en SAT/RIF o si lo manejas sin comprobantes.",
    "vehicle_use_signal": "vehicle_use",
    "vehicle_use_does_not_write_income": true
  },
  "income_resolution_policy": {
    "source": "Requisitos_Dinamo-Junio2026",
    "ambiguous_signals": [
      "tengo negocio",
      "negocio propio",
      "vendo comida",
      "vendo comida desde mi casa",
      "trabajo por mi cuenta",
      "tengo mi local",
      "soy independiente"
    ],
    "ambiguous_pending_slot": "business_tax_status",
    "ambiguous_clarification": "Va, si tienes negocio. Para darte el plan correcto dime si estas dado de alta en SAT/RIF o si lo manejas sin comprobantes.",
    "resolution_rules": [
      {
        "candidate": "nomina_tarjeta",
        "plan_id": "nomina_tarjeta_10",
        "evidence_any": ["me depositan en tarjeta", "me pagan por tarjeta", "nomina en tarjeta", "me pagan por banco", "deposito de nomina"]
      },
      {
        "candidate": "nomina_recibos",
        "plan_id": "nomina_recibos_15",
        "evidence_any": ["tengo recibos", "recibos de nomina", "me pagan con recibos", "comprobantes de nomina"]
      },
      {
        "candidate": "pensionado",
        "plan_id": "pensionados_imss_10",
        "evidence_any": ["soy pensionado", "recibo pension", "pensionado imss", "jubilado"]
      },
      {
        "candidate": "negocio_sat",
        "plan_id": "negocio_sat_15",
        "evidence_any": ["estoy dado de alta en sat", "tengo sat", "tengo rif", "constancia fiscal", "facturo", "tengo negocio registrado"]
      },
      {
        "candidate": "sin_comprobantes",
        "plan_id": "sin_comprobantes_20",
        "evidence_any": ["no tengo sat", "no tengo rif", "no estoy dado de alta", "no tengo comprobantes", "me pagan en efectivo", "informal", "no declaro", "sin comprobar ingresos"]
      },
      {
        "candidate": "guardia_seguridad",
        "plan_id": "guardia_seguridad_30",
        "evidence_any": ["guardia de seguridad", "soy guardia", "seguridad privada", "vigilante", "custodio", "policia", "fuerza civil"]
      }
    ]
  },
  "required_tools_policy": {
    "price_requires": ["catalog.search", "credit_plan.resolve", "quote.resolve"],
    "model_write_requires": ["catalog.search"],
    "requirements_requires": ["requirements.lookup"],
    "plan_write_requires": ["credit_plan.resolve"],
    "document_status_requires": ["document.check"],
    "expediente_complete_requires": ["expediente.evaluate"],
    "tool_skipped_or_failed_blocks_visible_send": true
  },
  "pipeline": {
    "id": "dinamo_product_agent_runtime_v2_no_send",
    "dry_run": true,
    "side_effects_enabled": false
  },
  "safety": {
    "live_send_enabled": false,
    "actions_enabled": false,
